<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd"
  objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
  <changeSet id="1756820490885-1" author="mmoya@PragmaInvest.com">
    <createTable tableName="request_states">
      <column defaultValueComputed="uuid_generate_v4()" name="id" type="uuid">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_request_states"/>
      </column>
      <column defaultValueBoolean="false" name="deleted" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="code" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>
  <changeSet id="1756820490885-2" author="mmoya@PragmaInvest.com">
    <addColumn tableName="friends">
      <column name="action" type="VARCHAR(255)"/>
      <column name="request_state_id" type="UUID"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756820490885-3" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="action" tableName="friends"/>
  </changeSet>
  <changeSet id="1756820490885-4" author="mmoya@PragmaInvest.com">
    <addColumn tableName="groups">
      <column name="action" type="VARCHAR(255)"/>
      <column name="publishing_context_id" type="UUID"/>
      <column name="request_state_id" type="UUID"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756820490885-5" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="action" tableName="groups"/>
  </changeSet>
  <changeSet id="1756820490885-6" author="mmoya@PragmaInvest.com">
    <addColumn tableName="social_networks">
      <column name="icon" type="VARCHAR(150)"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756820490885-7" author="mmoya@PragmaInvest.com">
    <addColumn tableName="comments">
      <column name="publishing_context_id" type="UUID"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756820490885-8" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="publishing_context_id" tableName="comments"/>
  </changeSet>
  <changeSet id="1756820490885-9" author="mmoya@PragmaInvest.com">
    <addColumn tableName="follows">
      <column name="publishing_context_id" type="UUID"/>
      <column name="region_id" type="UUID"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756820490885-10" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="publishing_context_id" tableName="follows"/>
  </changeSet>
  <changeSet id="1756820490885-12" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="publishing_context_id" tableName="groups"/>
  </changeSet>
  <changeSet id="1756820490885-14" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="region_id" tableName="follows"/>
  </changeSet>
  <changeSet id="1756820490885-16" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="request_state_id" tableName="friends"/>
  </changeSet>
  <changeSet id="1756820490885-18" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="request_state_id" tableName="groups"/>
  </changeSet>
  <changeSet id="1756820490885-19" author="mmoya@PragmaInvest.com">
    <addUniqueConstraint columnNames="code" constraintName="uc_request_states_code"
      tableName="request_states"/>
  </changeSet>
  <changeSet id="1756820490885-20" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="publishing_context_id" baseTableName="comments"
      constraintName="FK_COMMENTS_ON_PUBLISHING_CONTEXT" referencedColumnNames="id"
      referencedTableName="publishing_contexts"/>
  </changeSet>
  <changeSet id="1756820490885-21" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="publishing_context_id" baseTableName="follows"
      constraintName="FK_FOLLOWS_ON_PUBLISHING_CONTEXT" referencedColumnNames="id"
      referencedTableName="publishing_contexts"/>
  </changeSet>
  <changeSet id="1756820490885-22" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="region_id" baseTableName="follows"
      constraintName="FK_FOLLOWS_ON_REGION" referencedColumnNames="id"
      referencedTableName="regions"/>
  </changeSet>
  <changeSet id="1756820490885-23" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="request_state_id" baseTableName="friends"
      constraintName="FK_FRIENDS_ON_REQUEST_STATE" referencedColumnNames="id"
      referencedTableName="request_states"/>
  </changeSet>
  <changeSet id="1756820490885-24" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="publishing_context_id" baseTableName="groups"
      constraintName="FK_GROUPS_ON_PUBLISHING_CONTEXT" referencedColumnNames="id"
      referencedTableName="publishing_contexts"/>
  </changeSet>
  <changeSet id="1756820490885-25" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="request_state_id" baseTableName="groups"
      constraintName="FK_GROUPS_ON_REQUEST_STATE" referencedColumnNames="id"
      referencedTableName="request_states"/>
  </changeSet>
  <changeSet id="1756820490885-26" author="mmoya@PragmaInvest.com">
    <dropColumn columnName="is_join" tableName="groups"/>
  </changeSet>
  <changeSet id="1756820490885-27" author="mmoya@PragmaInvest.com">
    <dropColumn columnName="status" tableName="friends"/>
  </changeSet>

</databaseChangeLog>