<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd"
  objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
  <changeSet id="1758214016240-1" author="mmoya@PragmaInvest.com">
    <createTable tableName="account_follow_profiles">
      <column defaultValueComputed="uuid_generate_v4()" name="id" type="uuid">
        <constraints nullable="false" primaryKey="true"
          primaryKeyName="pk_account_follow_profiles"/>
      </column>
      <column defaultValueComputed="now()" name="created_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="VARCHAR(255)"/>
      <column defaultValueComputed="now()" name="updated_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="updated_by" type="VARCHAR(255)"/>
      <column defaultValueNumeric="0" name="version" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column defaultValueBoolean="false" name="deleted" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="followed_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="unfollowed_at" type="timestamp"/>
      <column name="follow_state" type="SMALLINT">
        <constraints nullable="false"/>
      </column>
      <column name="account_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="profile_id" type="UUID"/>
    </createTable>
  </changeSet>
  <changeSet id="1758214016240-2" author="mmoya@PragmaInvest.com">
    <createTable tableName="profiles">
      <column defaultValueComputed="uuid_generate_v4()" name="id" type="uuid">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_profiles"/>
      </column>
      <column defaultValueComputed="now()" name="created_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="VARCHAR(255)"/>
      <column defaultValueComputed="now()" name="updated_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="updated_by" type="VARCHAR(255)"/>
      <column defaultValueNumeric="0" name="version" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column defaultValueBoolean="false" name="deleted" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="region_id" type="UUID"/>
      <column name="publishing_context_id" type="UUID">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>
  <changeSet id="1758214016240-3" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="account_id" baseTableName="account_follow_profiles"
      constraintName="FK_ACCOUNT_FOLLOW_PROFILES_ON_ACCOUNT" referencedColumnNames="id"
      referencedTableName="accounts"/>
  </changeSet>
  <changeSet id="1758214016240-4" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="profile_id" baseTableName="account_follow_profiles"
      constraintName="FK_ACCOUNT_FOLLOW_PROFILES_ON_PROFILE" referencedColumnNames="id"
      referencedTableName="profiles"/>
  </changeSet>
  <changeSet id="1758214016240-5" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="publishing_context_id" baseTableName="profiles"
      constraintName="FK_PROFILES_ON_PUBLISHING_CONTEXT" referencedColumnNames="id"
      referencedTableName="publishing_contexts"/>
  </changeSet>
  <changeSet id="1758214016240-6" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="region_id" baseTableName="profiles"
      constraintName="FK_PROFILES_ON_REGION" referencedColumnNames="id"
      referencedTableName="regions"/>
  </changeSet>

</databaseChangeLog>