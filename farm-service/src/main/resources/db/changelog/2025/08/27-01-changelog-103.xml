<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd"
  objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
  <changeSet id="1756306895732-1" author="mmoya@PragmaInvest.com">
    <createTable tableName="device_connections">
      <column defaultValueComputed="uuid_generate_v4()" name="id" type="uuid">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_device_connections"/>
      </column>
      <column defaultValueComputed="now()" name="created_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="VARCHAR(255)"/>
      <column defaultValueComputed="now()" name="updated_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="updated_by" type="VARCHAR(255)"/>
      <column defaultValueNumeric="0" name="version" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column defaultValueBoolean="false" name="deleted" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="mac_address" type="VARCHAR(150)">
        <constraints nullable="false"/>
      </column>
      <column name="ip_address" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="ip_gateway" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="network_name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="device_id" type="UUID">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>
  <changeSet id="1756306895732-2" author="mmoya@PragmaInvest.com">
    <addColumn tableName="activities">
      <column name="account_id" type="UUID"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756306895732-3" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="account_id" tableName="activities"/>
  </changeSet>
  <changeSet id="1756306895732-4" author="mmoya@PragmaInvest.com">
    <addColumn tableName="publishings">
      <column name="description" type="VARCHAR(500)"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756306895732-5" author="mmoya@PragmaInvest.com">
    <addColumn tableName="chips">
      <column defaultValueBoolean="false" name="is_device_inside" type="boolean"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756306895732-6" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="is_device_inside" tableName="chips"/>
  </changeSet>
  <changeSet id="1756306895732-7" author="mmoya@PragmaInvest.com">
    <addColumn tableName="follows">
      <column defaultValueBoolean="false" name="is_following" type="boolean"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756306895732-8" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="is_following" tableName="follows"/>
  </changeSet>
  <changeSet id="1756306895732-9" author="mmoya@PragmaInvest.com">
    <addColumn tableName="groups">
      <column defaultValueBoolean="false" name="is_join" type="boolean"/>
    </addColumn>
  </changeSet>
  <changeSet id="1756306895732-10" author="mmoya@PragmaInvest.com">
    <addNotNullConstraint columnName="is_join" tableName="groups"/>
  </changeSet>
  <changeSet id="1756306895732-11" author="mmoya@PragmaInvest.com">
    <addUniqueConstraint columnNames="mac_address"
      constraintName="uc_device_connections_mac_address" tableName="device_connections"/>
  </changeSet>
  <changeSet id="1756306895732-12" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="account_id" baseTableName="activities"
      constraintName="FK_ACTIVITIES_ON_ACCOUNT" referencedColumnNames="id"
      referencedTableName="accounts"/>
  </changeSet>
  <changeSet id="1756306895732-13" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="device_id" baseTableName="device_connections"
      constraintName="FK_DEVICE_CONNECTIONS_ON_DEVICE" referencedColumnNames="id"
      referencedTableName="devices"/>
  </changeSet>
  <changeSet id="1756306895732-14" author="mmoya@PragmaInvest.com">
    <dropColumn columnName="mac_address" tableName="devices"/>
  </changeSet>
  <changeSet id="1756306895732-15" author="mmoya@PragmaInvest.com">
    <dropColumn columnName="status" tableName="follows"/>
  </changeSet>

</databaseChangeLog>