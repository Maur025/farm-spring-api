<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd"
  objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
  <changeSet id="1756390394060-4" author="mmoya@PragmaInvest.com">
    <dropForeignKeyConstraint baseTableName="activity_types"
      constraintName="fk_activity_types_on_social_network"/>
  </changeSet>
  <changeSet id="1756390394060-1" author="mmoya@PragmaInvest.com">
    <createTable tableName="social_network_actions">
      <column defaultValueComputed="uuid_generate_v4()" name="id" type="uuid">
        <constraints nullable="false" primaryKey="true" primaryKeyName="pk_social_network_actions"/>
      </column>
      <column defaultValueComputed="now()" name="created_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="created_by" type="VARCHAR(255)"/>
      <column defaultValueComputed="now()" name="updated_at" type="timestamp">
        <constraints nullable="false"/>
      </column>
      <column name="updated_by" type="VARCHAR(255)"/>
      <column defaultValueNumeric="0" name="version" type="bigint">
        <constraints nullable="false"/>
      </column>
      <column defaultValueBoolean="false" name="deleted" type="boolean">
        <constraints nullable="false"/>
      </column>
      <column name="social_network_id" type="UUID">
        <constraints nullable="false"/>
      </column>
      <column name="activity_type_id" type="UUID">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>
  <changeSet id="1756390394060-2" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="activity_type_id"
      baseTableName="social_network_actions"
      constraintName="FK_SOCIAL_NETWORK_ACTIONS_ON_ACTIVITY_TYPE" referencedColumnNames="id"
      referencedTableName="activity_types"/>
  </changeSet>
  <changeSet id="1756390394060-3" author="mmoya@PragmaInvest.com">
    <addForeignKeyConstraint baseColumnNames="social_network_id"
      baseTableName="social_network_actions"
      constraintName="FK_SOCIAL_NETWORK_ACTIONS_ON_SOCIAL_NETWORK" referencedColumnNames="id"
      referencedTableName="social_networks"/>
  </changeSet>
  <changeSet id="1756390394060-5" author="mmoya@PragmaInvest.com">
    <dropColumn columnName="social_network_id" tableName="activity_types"/>
  </changeSet>

</databaseChangeLog>